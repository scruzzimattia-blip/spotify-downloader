# Optional: Compose lädt diese Datei nur, wenn sie als ".env" im selben
# Verzeichnis liegt. Du kannst alles auch weglassen und Variablen in der
# Shell setzen oder direkt in docker-compose.yml eintragen.
#
# Eigene Spotify API Credentials:
# App anlegen: https://developer.spotify.com/dashboard
#   1. "Create app"
#   2. Beliebigen Namen/Beschreibung vergeben
#   3. Als Redirect URI z. B. http://127.0.0.1:8080/ eintragen (ungenutzt, aber Pflicht)
#   4. Nach dem Erstellen unter "Settings" -> "View client secret" abrufen
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Audio-Quellen für yt-dlp (kommagetrennt): soundcloud | youtube
# Standard nur SoundCloud — kein YouTube.
AUDIO_SOURCES=soundcloud

# Nur bei AUDIO_SOURCES=…,youtube: Netscape-Cookie-Datei, z. B.:
#   YTDLP_COOKIES_FILE=/etc/cookies.txt
YTDLP_COOKIES_FILE=
